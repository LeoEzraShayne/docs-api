generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  FREE
  ONESHOT
  STARTER
  PRO
  BUSINESS
}

enum ProjectStatus {
  DRAFT
  READY
  ARCHIVED
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum PaymentType {
  ONESHOT
  SUBSCRIPTION
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  googleSub    String?            @unique
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  projects     Project[]
  entitlement  Entitlement?
  loginCodes   LoginCode[]
  previewUsage PreviewUsage[]
  payments     Payment[]
}

model LoginCode {
  id         String       @id @default(cuid())
  email      String
  code       String
  provider   AuthProvider @default(EMAIL)
  ip         String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime     @default(now())
  userId     String?
  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([ip, createdAt])
}

model Project {
  id              String           @id @default(cuid())
  userId          String
  docTitle        String?
  formFields      Json             @default("{}")
  minutesText     String           @default("")
  status          ProjectStatus    @default(DRAFT)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastActivityAt  DateTime         @default(now())
  lastGenerateAt  DateTime?
  versions        ProjectVersion[]
  previewUsage    PreviewUsage[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model ProjectVersion {
  id             String   @id @default(cuid())
  projectId      String
  versionNo      Int
  quality        String
  extractedJson  Json
  idempotencyKey String?
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNo])
  @@unique([projectId, idempotencyKey])
}

model Entitlement {
  id                   String    @id @default(cuid())
  userId               String    @unique
  planType             PlanType  @default(FREE)
  oneshotCredits       Int       @default(0)
  quotaTotal           Int       @default(0)
  quotaUsed            Int       @default(0)
  periodStart          DateTime?
  periodEnd            DateTime?
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String      @id @default(cuid())
  userId            String
  type              PaymentType
  amountJpy         Int
  status            String
  stripeSessionId   String?     @unique
  stripeInvoiceId   String?     @unique
  stripeEventId     String?     @unique
  metadata          Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PreviewUsage {
  id        String   @id @default(cuid())
  userId    String?
  projectId String?
  ip        String?
  kind      String
  dateKey   String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([kind, dateKey, userId, projectId, ip])
  @@index([kind, dateKey])
}

model AlertState {
  id                      String   @id
  excelWorkerFailures     Int      @default(0)
  openAiFailures          Int      @default(0)
  stripeFailures          Int      @default(0)
  excelWindowStartedAt    DateTime?
  excelWindowTotal        Int      @default(0)
  excelWindowFailures     Int      @default(0)
  updatedAt               DateTime @updatedAt
}
